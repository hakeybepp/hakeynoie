# Database
POSTGRES_DB=hakeynoie
POSTGRES_USER=hakeynoie
POSTGRES_PASSWORD=hakeynoie_password

# Backend (Elixir/Phoenix)
# Note: use postgresql:// — no driver prefix
DATABASE_URL=postgresql://hakeynoie:hakeynoie_password@db:5432/hakeynoie
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS - comma-separated origins allowed
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
