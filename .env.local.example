# Database
POSTGRES_DB=sacamer
POSTGRES_USER=sacamer
POSTGRES_PASSWORD=sacamer_password

# Backend (Elixir/Phoenix)
# Note: use postgresql:// — no driver prefix
DATABASE_URL=postgresql://sacamer:sacamer_password@db:5432/sacamer
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS - comma-separated origins allowed
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
